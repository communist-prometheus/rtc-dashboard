---
import type { ConnectionEvent } from '@/models/telemetry';
import { formatDateTime, formatDuration } from '@/helpers/format';

interface Props {
  readonly connections: readonly ConnectionEvent[];
  readonly roomStart: string;
  readonly roomEnd: string | undefined;
}

const { connections, roomStart, roomEnd } = Astro.props;

const roomStartMs = new Date(roomStart).getTime();
const roomEndMs = roomEnd ? new Date(roomEnd).getTime() : Date.now();
const roomDurationMs = Math.max(roomEndMs - roomStartMs, 1);

const computeBarStyle = (joinedAt: string, leftAt: string | undefined): string => {
  const joinMs = new Date(joinedAt).getTime();
  const leaveMs = leftAt ? new Date(leftAt).getTime() : roomEndMs;
  const leftPercent = ((joinMs - roomStartMs) / roomDurationMs) * 100;
  const widthPercent = ((leaveMs - joinMs) / roomDurationMs) * 100;
  return `inset-inline-start: ${String(Math.max(0, leftPercent))}%; inline-size: ${String(Math.min(100 - leftPercent, widthPercent))}%;`;
};
---

<section aria-label="Connection timeline">
  <h3 class="heading">Connection Timeline</h3>

  {connections.length === 0 && (
    <p class="empty-state">No connections recorded.</p>
  )}

  <ol class="timeline-list" role="list">
    {connections.map((conn) => (
      <li class="timeline-entry">
        <header class="entry-header">
          <strong class="user-name">{conn.displayName}</strong>
          <span class="user-id">{conn.userId}</span>
        </header>
        <p class="entry-times">
          <time datetime={conn.joinedAt}>{formatDateTime(conn.joinedAt)}</time>
          <span aria-hidden="true"> &mdash; </span>
          {conn.leftAt ? (
            <time datetime={conn.leftAt}>{formatDateTime(conn.leftAt)}</time>
          ) : (
            <mark class="active-badge">Active</mark>
          )}
          <span class="duration">({formatDuration(conn.joinedAt, conn.leftAt)})</span>
        </p>
        <figure class="bar-container" aria-hidden="true">
          <span
            class:list={['bar', conn.leftAt ? 'completed' : 'active']}
            style={computeBarStyle(conn.joinedAt, conn.leftAt)}
          />
        </figure>
      </li>
    ))}
  </ol>
</section>

<style>
  .heading {
    font-size: 1.125rem;
    font-weight: 600;
    margin-block-end: var(--spacing-sm);
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-style: italic;
    padding: var(--spacing-md);
  }

  .timeline-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .timeline-entry {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .entry-header {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .user-name {
    font-weight: 600;
  }

  .user-id {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  .entry-times {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-block-start: 0.25rem;
  }

  .duration {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    margin-inline-start: var(--spacing-xs);
  }

  .active-badge {
    background: var(--color-success);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }

  .bar-container {
    position: relative;
    height: 0.375rem;
    background: var(--color-border);
    border-radius: 0.25rem;
    margin-block-start: var(--spacing-xs);
    overflow: hidden;
  }

  .bar {
    position: absolute;
    inset-block-start: 0;
    block-size: 100%;
    border-radius: 0.25rem;
    transition: inline-size var(--transition-base);
  }

  .bar.completed {
    background: var(--color-accent);
  }

  .bar.active {
    background: var(--color-success);
  }
</style>
