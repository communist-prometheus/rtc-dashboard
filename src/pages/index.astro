---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import StatsCard from '@/components/StatsCard.astro';
import { fetchRoomStats, fetchRecentSessions } from '@/services/telemetry-api';
import { formatNumber, formatDateTime, formatDuration } from '@/helpers/format';

const stats = await fetchRoomStats();
const sessions = await fetchRecentSessions();

const totalRooms = stats ? formatNumber(stats.totalRooms) : '--';
const activeRooms = stats ? formatNumber(stats.activeRooms) : '--';
const totalConnections = stats ? formatNumber(stats.totalConnections) : '--';
---

<DashboardLayout title="Overview" description="Telemetry overview for rtc-less WebRTC sessions">
  <header class="page-header">
    <h1>Dashboard Overview</h1>
    <p class="subtitle">Real-time telemetry for rtc-less WebRTC sessions</p>
  </header>

  <section aria-label="Key metrics">
    <dl class="stats-grid">
      <StatsCard label="Total Rooms" value={totalRooms} />
      <StatsCard label="Active Rooms" value={activeRooms} variant="success" />
      <StatsCard label="Total Connections" value={totalConnections} />
    </dl>
  </section>

  <section class="chart-section" aria-label="Room activity chart">
    <h2 class="section-heading">Room Activity</h2>
    <figure class="chart-container">
      <canvas id="room-activity-chart" aria-label="Room activity over time chart" role="img">
        Room activity line chart placeholder - data not yet loaded.
      </canvas>
    </figure>
  </section>

  <section class="sessions-section" aria-label="Recent room sessions">
    <h2 class="section-heading">Recent Sessions</h2>

    {!sessions || sessions.length === 0 ? (
      <p class="empty-state">No recent sessions found. The telemetry API may be unavailable.</p>
    ) : (
      <ul class="sessions-list" role="list">
        {sessions.map((session) => (
          <li>
            <a href={`/rooms/${session.roomId}`} class="session-card">
              <header class="session-header">
                <strong class="room-id">{session.roomId}</strong>
                {!session.closedAt && <mark class="live-badge">Live</mark>}
              </header>
              <dl class="session-meta">
                <dt class="visually-hidden">Started</dt>
                <dd>
                  <time datetime={session.createdAt}>{formatDateTime(session.createdAt)}</time>
                </dd>
                <dt class="visually-hidden">Duration</dt>
                <dd class="duration">{formatDuration(session.createdAt, session.closedAt)}</dd>
                <dt class="visually-hidden">Participants</dt>
                <dd class="participants">
                  {session.participantCount}
                  {session.participantCount === 1 ? ' user' : ' users'}
                </dd>
              </dl>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</DashboardLayout>

<script>
  import { Chart, registerables } from 'chart.js';

  Chart.register(...registerables);

  const initChart = (): void => {
    const canvas = document.getElementById('room-activity-chart');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const labels = Array.from({ length: 24 }, (_, i) => `${String(i).padStart(2, '0')}:00`);
    const placeholderData = labels.map(() => Math.floor(Math.random() * 10));

    const rootStyles = getComputedStyle(document.documentElement);
    const accentColor = rootStyles.getPropertyValue('--color-accent').trim();
    const textSecondary = rootStyles.getPropertyValue('--color-text-secondary').trim();
    const borderColor = rootStyles.getPropertyValue('--color-border').trim();

    new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Active Rooms',
            data: placeholderData,
            borderColor: accentColor,
            backgroundColor: `${accentColor}20`,
            fill: true,
            tension: 0.3,
            pointRadius: 2,
            pointHoverRadius: 5,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            labels: {
              color: textSecondary,
              font: { family: 'system-ui, sans-serif' },
            },
          },
        },
        scales: {
          x: {
            ticks: { color: textSecondary },
            grid: { color: borderColor },
          },
          y: {
            beginAtZero: true,
            ticks: { color: textSecondary },
            grid: { color: borderColor },
          },
        },
      },
    });
  };

  initChart();
  document.addEventListener('astro:after-swap', initChart);
</script>

<style>
  .page-header {
    margin-block-end: var(--spacing-lg);
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    margin-block-start: 0.25rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
    gap: var(--spacing-md);
    margin-block-end: var(--spacing-xl);
  }

  .section-heading {
    font-size: 1.25rem;
    font-weight: 600;
    margin-block-end: var(--spacing-sm);
  }

  .chart-section {
    margin-block-end: var(--spacing-xl);
  }

  .chart-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    height: 20rem;
    position: relative;
  }

  .sessions-section {
    margin-block-end: var(--spacing-xl);
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-style: italic;
    padding: var(--spacing-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .sessions-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .session-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-sm) var(--spacing-md);
    color: var(--color-text-primary);
    transition:
      box-shadow var(--transition-fast),
      border-color var(--transition-fast);
  }

  .session-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .session-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .session-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .room-id {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
  }

  .live-badge {
    background: var(--color-success);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.5rem;
    border-radius: 1rem;
  }

  .session-meta {
    display: flex;
    gap: var(--spacing-md);
    margin-block-start: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .duration {
    font-family: var(--font-mono);
  }

  .participants {
    font-weight: 500;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
