---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import StatsCard from '@/components/StatsCard.astro';
---

<DashboardLayout title="Overview" description="Telemetry overview for rtc-less WebRTC sessions">
  <header class="page-header">
    <h1>Dashboard Overview</h1>
    <p class="subtitle">Real-time telemetry for rtc-less WebRTC sessions</p>
  </header>

  <section aria-label="Key metrics">
    <dl class="stats-grid" id="stats-grid">
      <StatsCard label="Total Rooms" value="--" />
      <StatsCard label="Active Rooms" value="--" variant="success" />
      <StatsCard label="Total Connections" value="--" />
    </dl>
  </section>

  <section class="sessions-section" aria-label="Recent room sessions">
    <h2 class="section-heading">Recent Sessions</h2>
    <p class="empty-state" id="sessions-empty" hidden>No recent sessions yet — open a room and the entry will appear here within seconds.</p>
    <p class="empty-state" id="sessions-loading">Loading sessions…</p>
    <p class="empty-state" id="sessions-error" hidden>Telemetry API unreachable. <a href="https://telemetry.comprom.org/health">Check health endpoint</a>.</p>
    <ul class="sessions-list" id="sessions-list" role="list" hidden></ul>
  </section>
</DashboardLayout>

<script>
  import {
    fetchRoomStats,
    fetchRecentSessions,
  } from '@/services/telemetry-api'
  import { formatNumber, formatDateTime, formatDuration } from '@/helpers/format'
  import type { RoomSession } from '@/models/telemetry'

  const REFRESH_MS = 5_000

  const setStat = (label: string, value: string): void => {
    const cards = document.querySelectorAll<HTMLElement>(
      '#stats-grid > .stats-card'
    )
    for (const card of cards) {
      const dt = card.querySelector('dt')
      if (dt?.textContent?.trim() === label) {
        const dd = card.querySelector('dd')
        if (dd) dd.textContent = value
      }
    }
  }

  const renderSessions = (sessions: readonly RoomSession[]): void => {
    const list = document.getElementById('sessions-list')
    const empty = document.getElementById('sessions-empty')
    const loading = document.getElementById('sessions-loading')
    if (!list || !empty || !loading) return
    loading.hidden = true
    if (sessions.length === 0) {
      empty.hidden = false
      list.hidden = true
      return
    }
    empty.hidden = true
    list.hidden = false
    list.innerHTML = ''
    for (const s of sessions) {
      const li = document.createElement('li')
      const a = document.createElement('a')
      a.className = 'session-card'
      a.href = `/rooms?id=${encodeURIComponent(s.roomId)}`

      const header = document.createElement('header')
      header.className = 'session-header'
      const strong = document.createElement('strong')
      strong.className = 'room-id'
      strong.textContent = s.roomId
      header.appendChild(strong)
      if (!s.closedAt) {
        const live = document.createElement('mark')
        live.className = 'live-badge'
        live.textContent = 'Live'
        header.appendChild(live)
      }

      const dl = document.createElement('dl')
      dl.className = 'session-meta'
      const created = document.createElement('dd')
      const time = document.createElement('time')
      time.dateTime = s.createdAt
      time.textContent = formatDateTime(s.createdAt)
      created.appendChild(time)
      const duration = document.createElement('dd')
      duration.className = 'duration'
      duration.textContent = formatDuration(s.createdAt, s.closedAt)
      const participants = document.createElement('dd')
      participants.className = 'participants'
      participants.textContent =
        `${String(s.participantCount)} ${s.participantCount === 1 ? 'user' : 'users'}`
      dl.append(created, duration, participants)

      a.append(header, dl)
      li.append(a)
      list.append(li)
    }
  }

  const showError = (): void => {
    const loading = document.getElementById('sessions-loading')
    const error = document.getElementById('sessions-error')
    if (loading) loading.hidden = true
    if (error) error.hidden = false
  }

  const refresh = async (): Promise<void> => {
    const [stats, sessions] = await Promise.all([
      fetchRoomStats(),
      fetchRecentSessions(),
    ])
    if (!stats && !sessions) {
      showError()
      return
    }
    if (stats) {
      setStat('Total Rooms', formatNumber(stats.totalRooms))
      setStat('Active Rooms', formatNumber(stats.activeRooms))
      setStat('Total Connections', formatNumber(stats.totalConnections))
    }
    if (sessions) renderSessions(sessions)
  }

  void refresh()
  setInterval(() => { void refresh() }, REFRESH_MS)
  document.addEventListener('astro:after-swap', () => { void refresh() })
</script>

<style>
  .page-header {
    margin-block-end: var(--spacing-lg);
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    margin-block-start: 0.25rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
    gap: var(--spacing-md);
    margin-block-end: var(--spacing-xl);
  }

  .section-heading {
    font-size: 1.25rem;
    font-weight: 600;
    margin-block-end: var(--spacing-sm);
  }

  .sessions-section {
    margin-block-end: var(--spacing-xl);
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-style: italic;
    padding: var(--spacing-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .sessions-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .session-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-sm) var(--spacing-md);
    color: var(--color-text-primary);
    text-decoration: none;
    transition:
      box-shadow var(--transition-fast),
      border-color var(--transition-fast);
  }

  .session-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .session-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .session-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .room-id {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
  }

  .live-badge {
    background: var(--color-success);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.5rem;
    border-radius: 1rem;
  }

  .session-meta {
    display: flex;
    gap: var(--spacing-md);
    margin-block-start: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .duration {
    font-family: var(--font-mono);
  }

  .participants {
    font-weight: 500;
  }
</style>
