---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import ConnectionTimeline from '@/components/ConnectionTimeline.astro';
import { fetchRoomDetail } from '@/services/telemetry-api';
import { formatDateTime } from '@/helpers/format';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/');
}

const room = await fetchRoomDetail(id);
---

<DashboardLayout title={`Room ${id}`} description={`Telemetry detail for room ${id}`}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Dashboard</a></li>
      <li aria-current="page">Room {id}</li>
    </ol>
  </nav>

  {!room ? (
    <section class="error-state" aria-label="Room not found">
      <h1>Room Not Found</h1>
      <p>Could not load telemetry data for room <code>{id}</code>. The telemetry API may be unavailable.</p>
      <a href="/" class="back-link">Back to Dashboard</a>
    </section>
  ) : (
    <article>
      <header class="page-header">
        <h1 class="room-title">
          Room <code>{room.roomId}</code>
          {!room.closedAt && <mark class="live-badge">Live</mark>}
        </h1>
        <dl class="room-meta">
          <dt>Created</dt>
          <dd><time datetime={room.createdAt}>{formatDateTime(room.createdAt)}</time></dd>
          {room.closedAt && (
            <>
              <dt>Closed</dt>
              <dd><time datetime={room.closedAt}>{formatDateTime(room.closedAt)}</time></dd>
            </>
          )}
          <dt>Connections</dt>
          <dd>{room.connections.length}</dd>
        </dl>
      </header>

      <section class="timeline-section">
        <ConnectionTimeline
          connections={room.connections}
          roomStart={room.createdAt}
          roomEnd={room.closedAt}
        />
      </section>

      <section class="ice-section" aria-label="ICE events log">
        <h2 class="section-heading">ICE Events</h2>
        {room.iceEvents.length === 0 ? (
          <p class="empty-state">No ICE events recorded.</p>
        ) : (
          <figure class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th scope="col">Timestamp</th>
                  <th scope="col">Type</th>
                  <th scope="col">Candidate</th>
                  <th scope="col">Protocol</th>
                  <th scope="col">Address</th>
                </tr>
              </thead>
              <tbody>
                {room.iceEvents.map((event) => (
                  <tr>
                    <td>
                      <time datetime={event.timestamp}>{formatDateTime(event.timestamp)}</time>
                    </td>
                    <td>
                      <code>{event.type}</code>
                    </td>
                    <td>{event.candidateType}</td>
                    <td>
                      <code>{event.protocol}</code>
                    </td>
                    <td>
                      <code>{event.address}</code>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </figure>
        )}
      </section>

      <section class="quality-section" aria-label="Quality metrics chart">
        <h2 class="section-heading">Quality Metrics</h2>
        <figure class="chart-container">
          <canvas
            id="quality-chart"
            aria-label="Quality metrics over time"
            role="img"
            data-metrics={JSON.stringify(room.qualityMetrics)}
          >
            Quality metrics chart placeholder.
          </canvas>
        </figure>
      </section>
    </article>
  )}
</DashboardLayout>

<script>
  import { Chart, registerables } from 'chart.js';
  import type { QualityMetric } from '@/models/telemetry';

  Chart.register(...registerables);

  const initQualityChart = (): void => {
    const canvas = document.getElementById('quality-chart');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const raw = canvas.dataset['metrics'];
    const metrics: readonly QualityMetric[] = raw ? (JSON.parse(raw) as readonly QualityMetric[]) : [];

    const rootStyles = getComputedStyle(document.documentElement);
    const accentColor = rootStyles.getPropertyValue('--color-accent').trim();
    const successColor = rootStyles.getPropertyValue('--color-success').trim();
    const warningColor = rootStyles.getPropertyValue('--color-warning').trim();
    const textSecondary = rootStyles.getPropertyValue('--color-text-secondary').trim();
    const borderColor = rootStyles.getPropertyValue('--color-border').trim();

    const labels = metrics.length > 0
      ? metrics.map((m) => new Date(m.timestamp).toLocaleTimeString())
      : Array.from({ length: 12 }, (_, i) => `T+${String(i * 5)}s`);

    const bitrateData = metrics.length > 0
      ? metrics.map((m) => m.bitrate)
      : labels.map(() => Math.floor(Math.random() * 2000) + 500);

    const packetLossData = metrics.length > 0
      ? metrics.map((m) => m.packetLoss)
      : labels.map(() => Math.random() * 5);

    const rttData = metrics.length > 0
      ? metrics.map((m) => m.roundTripTime)
      : labels.map(() => Math.floor(Math.random() * 100) + 20);

    new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Bitrate (kbps)',
            data: bitrateData,
            borderColor: accentColor,
            backgroundColor: 'transparent',
            yAxisID: 'y',
            tension: 0.3,
            pointRadius: 2,
          },
          {
            label: 'Packet Loss (%)',
            data: packetLossData,
            borderColor: warningColor,
            backgroundColor: 'transparent',
            yAxisID: 'y1',
            tension: 0.3,
            pointRadius: 2,
          },
          {
            label: 'RTT (ms)',
            data: rttData,
            borderColor: successColor,
            backgroundColor: 'transparent',
            yAxisID: 'y1',
            tension: 0.3,
            pointRadius: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
        },
        plugins: {
          legend: {
            labels: {
              color: textSecondary,
              font: { family: 'system-ui, sans-serif' },
            },
          },
        },
        scales: {
          x: {
            ticks: { color: textSecondary },
            grid: { color: borderColor },
          },
          y: {
            type: 'linear',
            position: 'left',
            beginAtZero: true,
            title: { display: true, text: 'Bitrate (kbps)', color: textSecondary },
            ticks: { color: textSecondary },
            grid: { color: borderColor },
          },
          y1: {
            type: 'linear',
            position: 'right',
            beginAtZero: true,
            title: { display: true, text: 'Loss (%) / RTT (ms)', color: textSecondary },
            ticks: { color: textSecondary },
            grid: { drawOnChartArea: false },
          },
        },
      },
    });
  };

  initQualityChart();
  document.addEventListener('astro:after-swap', initQualityChart);
</script>

<style>
  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    list-style: none;
    padding: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-block-end: var(--spacing-md);
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    margin-inline-start: var(--spacing-xs);
    color: var(--color-text-secondary);
  }

  .breadcrumb a {
    color: var(--color-accent);
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 0.125rem;
  }

  .error-state {
    text-align: center;
    padding: var(--spacing-2xl);
  }

  .error-state h1 {
    font-size: 1.5rem;
    margin-block-end: var(--spacing-sm);
  }

  .error-state p {
    color: var(--color-text-secondary);
    margin-block-end: var(--spacing-md);
  }

  .error-state code {
    font-family: var(--font-mono);
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-md);
    background: var(--color-accent);
    color: var(--color-on-accent);
    border-radius: var(--radius-sm);
    font-weight: 500;
    transition: background var(--transition-fast);
  }

  .back-link:hover {
    background: var(--color-accent-hover);
  }

  .back-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .page-header {
    margin-block-end: var(--spacing-lg);
  }

  .room-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .room-title code {
    font-family: var(--font-mono);
    font-size: 1.25rem;
  }

  .live-badge {
    background: var(--color-success);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.5rem;
    border-radius: 1rem;
  }

  .room-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs) var(--spacing-md);
    margin-block-start: var(--spacing-xs);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .room-meta dt {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .room-meta dd {
    margin-inline-end: var(--spacing-sm);
  }

  .timeline-section {
    margin-block-end: var(--spacing-xl);
  }

  .ice-section {
    margin-block-end: var(--spacing-xl);
  }

  .section-heading {
    font-size: 1.125rem;
    font-weight: 600;
    margin-block-end: var(--spacing-sm);
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-style: italic;
    padding: var(--spacing-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }

  thead {
    background: var(--color-surface);
  }

  th {
    text-align: start;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.6875rem;
    border-block-end: 1px solid var(--color-border);
    white-space: nowrap;
  }

  td {
    padding: var(--spacing-xs) var(--spacing-sm);
    border-block-end: 1px solid var(--color-border);
    white-space: nowrap;
  }

  td code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--color-surface);
    padding: 0.0625rem 0.25rem;
    border-radius: 0.25rem;
  }

  tbody tr:last-child td {
    border-block-end: none;
  }

  .quality-section {
    margin-block-end: var(--spacing-xl);
  }

  .chart-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    height: 22rem;
    position: relative;
  }
</style>
